# Copy to `.env.local` and fill. The repo’s `web/.env.local` is the full template
# (includes future / production placeholders not yet read by the app).

### Auth — email verification, password reset, sessions (custom auth)
#
# --- Signup: external email + phone checks (optional API keys) ---
# MailSniper: primary — https://mailsniperapp.com — GET /v1/verify/email/{email} with Bearer key
# MAILSNIPER_API_KEY=
# Bloombox (fallback, no key): same-origin POST JSON; override URL if needed
# BLOOMBOX_EMAIL_VALIDATE_URL=https://rapid-email-verifier.fly.dev/api/validate
# NumVerify: phone check on profile + account SMS — https://numverify.com
# NUMVERIFY_API_KEY=
# End-to-end tests only: skip MailSniper/Bloombox
# SKIP_EMAIL_EXTERNAL_VALIDATION=0
#
# --- Email delivery (verification + password reset) ---
# If AUTH_EMAIL_MODE is unset, it defaults to "dev": messages are ONLY printed to the server log (no inbox).
# For real delivery in staging/production:
#   AUTH_EMAIL_MODE=ses
#   AWS_SES_FROM="SkillRise <verify@yourdomain.com>"   # must be a verified identity in SES
#   AWS_REGION=us-east-1                                # must match the region where that identity was verified
# Optional: AWS_SES_REGION=us-east-1 if SES is in a different region than other AWS resources.
# Optional: EMAIL_STRICT_PRODUCTION=1 — if set, refuse to run log-only email when NODE_ENV=production (fails send).
# IAM: credentials used at runtime need ses:SendEmail (and usually ses:SendRawEmail if you switch APIs later).
# SES sandbox: you can only send TO verified addresses until you request production access in the SES console.
# Public site URL (links inside emails, OAuth). Use your App Runner / custom domain in production, e.g.:
# APP_BASE_URL=https://skillrise.tech
# NEXT_PUBLIC_APP_URL=https://skillrise.tech
# AWS_SES_FROM="SkillRise <noreply@skillrise.tech>"   # same domain as verified in SES
#
# AUTH_EMAIL_MODE=dev
# AWS_SES_FROM="SkillRise <noreply@yourdomain.com>"
# AWS_REGION=us-east-1
# Password reset link TTL (ms). Default 1 hour; min 5 m, max 24 h.
# PASSWORD_RESET_TTL_MS=3600000
# Google OAuth (sign in / sign up) — set both + redirect in Google Cloud Console
# (APIs & Services → Credentials → OAuth 2.0 Web client).
# Redirect URI: {origin}/api/auth/google/callback (e.g. http://localhost:3000/api/auth/google/callback for dev)
# # GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# # GOOGLE_OAUTH_CLIENT_SECRET=...
# # NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
#   (optional but recommended; stable public origin for OAuth redirect + links)
# (See AWS Cognito block for hosted IdP alternatives.)

### Data store
# "memory" (default, ephemeral demo data) | "mongodb" | "dynamodb"
DATA_STORE=memory

### AI Tutor (optional — falls back to a smart mock if missing)
# Default (no AI_TUTOR_PROVIDER): Gemini (AI Studio) first; if it errors, times out, or rate-limits, OpenAI is used when OPENAI_API_KEY is set.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Google Gemini (AI Studio) — https://aistudio.google.com/apikey
# # GEMINI_API_KEY=
# # GOOGLE_API_KEY=   (optional alias if GEMINI_API_KEY empty)
# # GEMINI_API_MODEL=gemini-2.5-flash
# # GEMINI_STREAM_FIRST_TOKEN_MS=60000   (streaming: max wait for first token before OpenAI fallback)
# # GEMINI_REQUEST_TIMEOUT_MS=120000     (non-streaming request cap)
# Vertex AI (enterprise) — # GOOGLE_CLOUD_PROJECT, GOOGLE_APPLICATION_CREDENTIALS, etc.
# # AI_TUTOR_PROVIDER=openai|gemini|vertex|google|aistudio|google_ai
# #   openai = OpenAI only; gemini/aistudio/google_ai = Gemini then OpenAI fallback; vertex = Vertex only; google = Gemini (fallback) or Vertex

### MongoDB (only when DATA_STORE=mongodb)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true
# MONGODB_DB=skillrise

### DynamoDB (only when DATA_STORE=dynamodb)
# AWS_REGION=us-east-1
# DYNAMO_TABLE=skillrise-prod-table

### AWS Cognito (optional, used when swapping the built-in session auth)
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# COGNITO_DOMAIN=

### SMS (optional — phone verification on profile, not for sign-in)
# SMS_MODE=off        — hide/disable SMS in the app
# SMS_MODE=dev        — log verification codes to the server console (default when Twilio not set)
# SMS_MODE=twilio     — send real SMS (requires Twilio credentials)
# SMS_MODE=sns        — send SMS via Amazon SNS (same AWS credential chain as SES; IAM: sns:Publish)
# AWS_SNS_REGION=us-east-1   — optional; defaults to AWS_REGION
# In development: public “receive SMS online” link shown in the verify UI (testing only, not private)
# RECEIVESMS_DEV_URL=https://receivesms.me
# Twilio: https://console.twilio.com — use a trial number or Messaging Service
# # TWILIO_ACCOUNT_SID=AC…
# # TWILIO_AUTH_TOKEN=…
# # TWILIO_SMS_FROM=+15551234567
#   or use a Messaging Service instead of a single From:
# # TWILIO_MESSAGING_SERVICE_SID=MG…

### S3 uploads (optional)
# UPLOADS_BUCKET=skillrise-prod-uploads-xxxx

### Skill search (optional — falls back to curated channels if missing)
# Get a key at https://console.cloud.google.com/ → enable "YouTube Data API v3"
# YOUTUBE_API_KEY=AIza...

### Unified free course search (optional extras)
# YouTube: same YOUTUBE_API_KEY as above — powers YouTube rows in /courses/search.
# MIT + Khan + Simplilearn (site: search): set one or both.
# BRAVE_SEARCH_API_KEY=
# SERPER_API_KEY=
# COURSES_CACHE_TTL_HOURS=12
#
# Coursera for Business — OAuth client + org id (https://dev.coursera.com)
# Without these, Coursera still works via the public HTML catalog path; the API adds org programs when valid.
# If token returns invalid_client, confirm Client ID/Secret in the Coursera app (Basic auth = base64(id:secret)).
# COURSERA_CLIENT_ID=
# COURSERA_CLIENT_SECRET=
# COURSERA_ORGANIZATION_ID=
# (alias) COURSERA_BUSINESS_ID=

### Tiered web video search (both free)
# Brave Search:  1,000 free/month — https://api-dashboard.search.brave.com
# BRAVE_SEARCH_API_KEY=
# Serper.dev:    2,500 free total — https://serper.dev
# SERPER_API_KEY=
# SEARCH_CACHE_TTL_HOURS=36
# (Same keys power MIT + Khan “site:” course discovery in unified free-course search.)
# COURSES_CACHE_TTL_HOURS=12

### Jobs providers — each one is optional, but add as many as you can.
# The orchestrator merges results from every provider that's configured.

# Adzuna (free dev tier, 250 calls/day). Sign up: https://developer.adzuna.com
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# ADZUNA_COUNTRY=us  # 2-letter lowercase, default us

# USAJobs (free, unlimited, federal jobs). Sign up: https://developer.usajobs.gov
# USAJOBS_EMAIL=your-registered@email.com
# USAJOBS_API_KEY=

# Remotive is public and keyless — always on, no setup needed.

### Apify (optional, paid or free-tier actor)
# APIFY_API_TOKEN=
# APIFY_ACTOR_JOB_SCRAPER=potent_xenoblast~linkedin-indeed-job-scraper
# APIFY_ACTOR_MEDIA_EXTRACTOR=abotapi~universal-media-extractor
# APIFY_ACTOR_CONTENT_PROCESSOR=valid_headlamp~ai-content-processor
# APIFY_ACTOR_VIDEO_TRANSCRIPT=thepattyroller~elite-video-processing-lite
# APIFY_ACTOR_RAG_BROWSER=apify~rag-web-browser
# JOBS_CACHE_TTL_HOURS=8
